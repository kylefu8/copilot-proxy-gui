{
  "name": "copilot-proxy-gui",
  "private": true,
  "version": "0.2.4",
  "description": "Desktop GUI for copilot-proxy — Electron + React + Vite",
  "type": "module",
  "main": "electron/main.cjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/kylefu8/copilot-proxy-gui.git"
  },
  "author": "kylefu8",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "desktop:dev": "concurrently -k \"vite\" \"wait-on tcp:5190 && cross-env COPILOT_GUI_DEV=1 electron ./electron/main.cjs\"",
    "desktop:start": "cross-env COPILOT_GUI_DEV=0 electron ./electron/main.cjs",
    "desktop:icons": "node scripts/generate-icons.cjs",
    "desktop:build": "node scripts/build-exe.cjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "citty": "^0.2.1",
    "clipboardy": "^5.3.1",
    "concurrently": "^9.2.1",
    "consola": "^3.4.2",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.27.3",
    "fetch-event-stream": "^0.1.6",
    "gpt-tokenizer": "^3.4.0",
    "hono": "^4.12.3",
    "proxy-from-env": "^2.0.0",
    "srvx": "^0.11.8",
    "tiny-invariant": "^1.3.3",
    "undici": "^7.22.0",
    "vite": "^5.4.20",
    "wait-on": "^8.0.5",
    "zod": "^4.3.6"
  }
}
